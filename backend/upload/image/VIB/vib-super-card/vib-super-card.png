    float: left;
    position: relative;
    display: flex;
    margin-bottom: 24px;
}
.title .view-link {
    color: var(--color-dard-orange);
    font-weight: 600;
    line-height: 34px;
    position: relative;
    padding-right: 30px;
	margin: 0;
}

.title .view-link-text,
.title a.view-link-text.new-style-link {
    color: var(--color-dard-orange) !important;
    font-size: 16px !important;
