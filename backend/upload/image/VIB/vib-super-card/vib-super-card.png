}
.vib-v2-world-box .vib-v2-content_world-box::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  box-shadow: 0px 0px 5px rgb(0 0 0 / 8%);
}
.vib-v2-box-txt-world-new-2 {
